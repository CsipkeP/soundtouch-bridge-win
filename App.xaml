<Application x:Class="BoseSoundTouchBridge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:loc="clr-namespace:BoseSoundTouchBridge.Localization"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <tb:TaskbarIcon x:Key="TrayIcon"
                            IconSource="Assets/app.ico"
                            ToolTipText="Bose SoundTouch Bridge"
                            TrayLeftMouseUp="TrayIcon_LeftMouseUp">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{x:Static loc:L.TraySettings}" Click="ShowSettings_Click"/>
                        <MenuItem Header="{x:Static loc:L.TraySpotify}" Click="SpotifySettings_Click"/>
                        <MenuItem Header="{x:Static loc:L.TrayReconnect}" Click="Reconnect_Click"/>
                        <Separator/>
                        <MenuItem Header="{x:Static loc:L.TrayHelp}" Click="ShowHelp_Click"/>
                        <Separator/>
                        <MenuItem Header="{x:Static loc:L.TrayExit}" Click="Exit_Click"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>
