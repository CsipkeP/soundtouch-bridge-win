<Window x:Class="BoseSoundTouchBridge.DiscoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:BoseSoundTouchBridge.Localization"
        Title="{x:Static loc:L.DiscoveryTitle}"
        Width="480" Height="380"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="13"
        Icon="Assets/app.ico"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock x:Name="StatusText" Text="{x:Static loc:L.DiscoverySearching}" VerticalAlignment="Center"/>
            <ProgressBar x:Name="ProgressBar" IsIndeterminate="True"
                         Width="180" Height="6" Margin="12,0,0,0"
                         VerticalAlignment="Center"/>
        </StackPanel>

        <ListBox Grid.Row="1" x:Name="DevicesList"
                 MouseDoubleClick="DevicesList_DoubleClick"
                 SelectionChanged="DevicesList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4,6">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock FontSize="11" Foreground="#666">
                            <Run Text="{Binding Ip, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding Model, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static loc:L.DiscoveryResearchButton}" Click="Research_Click" Padding="12,6" MinWidth="100"/>
            <Button Content="{x:Static loc:L.DiscoveryCancelButton}" Click="Cancel_Click" Padding="12,6" MinWidth="80" Margin="8,0,0,0"
                    IsCancel="True"/>
            <Button x:Name="OkButton" Content="{x:Static loc:L.DiscoverySelectButton}" Click="Ok_Click" IsEnabled="False"
                    Padding="12,6" MinWidth="100" Margin="8,0,0,0"
                    Background="#0078D4" Foreground="White" BorderBrush="#0078D4"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
