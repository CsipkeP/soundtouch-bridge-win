<Window x:Class="BoseSoundTouchBridge.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:BoseSoundTouchBridge.Localization"
        Title="{x:Static loc:L.HelpTooltip}"
        Width="820" Height="720"
        WindowStartupLocation="CenterOwner"
        Icon="Assets/app.ico"
        FontFamily="Segoe UI" FontSize="13"
        ShowInTaskbar="False">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static loc:L.CloseButton}" Click="Close_Click"
                    Padding="14,6" MinWidth="80" IsCancel="True" IsDefault="True"/>
        </StackPanel>

        <FlowDocumentScrollViewer x:Name="Viewer"
                                  VerticalScrollBarVisibility="Auto"
                                  ZoomIncrement="10" MinZoom="80" MaxZoom="200"/>
    </DockPanel>
</Window>
