<Window x:Class="BoseSoundTouchBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:BoseSoundTouchBridge.Localization"
        Title="{x:Static loc:L.MainTitle}"
        Width="720" Height="640"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/app.ico"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
        <Style TargetType="Button" x:Key="IconButton">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style TargetType="Button" x:Key="PresetButton">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <!-- Header: IP + status + controls -->
        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Label}"
                           Text="{x:Static loc:L.IpAddressLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="IpTextBox"/>
                <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource IconButton}"
                        Click="Search_Click" ToolTip="{x:Static loc:L.SearchDeviceTooltip}"
                        Content="&#xE721;"/>

                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="Gray"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="StatusText" Text="{x:Static loc:L.StatusWaiting}" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource IconButton}" Click="ReconnectInline_Click"
                                ToolTip="{x:Static loc:L.ReconnectTooltip}"
                                Width="32" Height="28" FontSize="14"
                                Content="&#xE895;" Margin="12,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="LangButton" Click="LangToggle_Click"
                                ToolTip="{x:Static loc:L.LangToggleTooltip}"
                                Padding="10,4" MinWidth="48" FontWeight="SemiBold"
                                Margin="0,0,8,0"/>
                        <Button Click="SpotifySettings_Click"
                                Content="{x:Static loc:L.SpotifyConnectButton}"
                                Background="#1DB954" Foreground="White" BorderBrush="#1DB954"
                                Padding="12,4" MinWidth="0" FontWeight="SemiBold"/>
                        <Button Style="{StaticResource IconButton}" Click="ShowHelp_Click"
                                ToolTip="{x:Static loc:L.HelpTooltip}"
                                Width="32" Height="28" FontSize="14"
                                Content="&#xE897;" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                        Background="#F5F7FA" BorderBrush="#E5E9EE" BorderThickness="1"
                        CornerRadius="6" Padding="10" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PowerButton" Style="{StaticResource IconButton}"
                                Click="Power_Click" ToolTip="{x:Static loc:L.PowerTooltip}">
                            <TextBlock x:Name="PowerIcon" Text="&#xE7E8;"
                                       Foreground="#888888"/>
                        </Button>
                        <Button x:Name="MuteButton" Style="{StaticResource IconButton}"
                                Click="Mute_Click" ToolTip="{x:Static loc:L.MuteTooltip}"
                                Margin="8,0,0,0">
                            <TextBlock x:Name="MuteIcon" Text="&#xE767;"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Click="VolumeDown_Click"
                                ToolTip="{x:Static loc:L.VolumeDownTooltip}" Width="40"
                                Margin="16,0,4,0"
                                Content="&#xE993;"/>
                        <Slider x:Name="VolumeSlider" Width="220" Minimum="0" Maximum="100"
                                IsMoveToPointEnabled="True" SmallChange="1" LargeChange="5"
                                VerticalAlignment="Center"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                        <Button Style="{StaticResource IconButton}" Click="VolumeUp_Click"
                                ToolTip="{x:Static loc:L.VolumeUpTooltip}" Width="40"
                                Margin="4,0,0,0"
                                Content="&#xE995;"/>
                        <TextBlock x:Name="VolumeLabel" Text="—" MinWidth="36"
                                   TextAlignment="Right" VerticalAlignment="Center"
                                   Margin="10,0,0,0" FontWeight="SemiBold"/>
                        <Button Style="{StaticResource IconButton}" Click="RefreshState_Click"
                                ToolTip="{x:Static loc:L.RefreshStateTooltip}"
                                Margin="16,0,0,0"
                                Content="&#xE72C;"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Footer: Save -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="HintText" Text=""
                       Foreground="#888" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="{x:Static loc:L.CloseButton}" Click="Close_Click" Margin="0,0,8,0"/>
            <Button Content="{x:Static loc:L.SaveAndReconnectButton}" Click="Save_Click"
                    Background="#0078D4" Foreground="White" BorderBrush="#0078D4"/>
        </StackPanel>

        <!-- Presets list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PresetItems">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EEE" BorderThickness="1" CornerRadius="6"
                                Padding="10" Margin="0,0,0,8" Background="#FAFAFA">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                        Click="TestPreset_Click"
                                        CommandParameter="{Binding Index}"
                                        ToolTip="{x:Static loc:L.PresetTestTooltip}"
                                        Content="{Binding Index}"
                                        Width="44" Height="44" MinWidth="0" Padding="0"
                                        FontSize="20" FontWeight="Bold"
                                        Background="#0078D4" Foreground="White"
                                        BorderBrush="#005EAA"
                                        VerticalAlignment="Center" Margin="0,0,12,0"/>

                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="Név"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,6,8,0" Tag="URL"/>

                                <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
                                        Click="BrowseRadio_Click"
                                        CommandParameter="{Binding Index}"
                                        ToolTip="{x:Static loc:L.RadioBrowseTooltip}"
                                        Width="44" Height="44" MinWidth="0" Padding="0"
                                        FontFamily="Segoe UI Emoji" FontSize="18"
                                        Content="📻"
                                        VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
