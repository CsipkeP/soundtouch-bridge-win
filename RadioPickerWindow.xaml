<Window x:Class="BoseSoundTouchBridge.RadioPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:BoseSoundTouchBridge.Localization"
        Title="{x:Static loc:L.RadioPickerTitle}"
        Width="920" Height="640"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="13"
        Icon="Assets/app.ico"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{x:Static loc:L.RadioPickerHeader}"
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{x:Static loc:L.CountryLabel}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="1" x:Name="CountryCombo"
                      Margin="0,0,16,0" Padding="6,4"
                      DisplayMemberPath="Display"
                      SelectionChanged="Filter_Changed"/>

            <TextBlock Grid.Column="2" Text="{x:Static loc:L.GenreLabel}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="3" x:Name="TagCombo"
                      Margin="0,0,16,0" Padding="6,4"
                      DisplayMemberPath="Display"
                      SelectionChanged="Filter_Changed"/>

            <TextBlock Grid.Column="4" Text="{x:Static loc:L.NameLabel}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="5" x:Name="NameSearch"
                     Margin="0,0,16,0" Padding="6,4"
                     VerticalContentAlignment="Center"
                     KeyDown="NameSearch_KeyDown"/>

            <Button Grid.Column="6" Content="{x:Static loc:L.SearchButton}" Click="Search_Click"
                    Padding="12,6" MinWidth="84"/>
        </Grid>

        <DataGrid Grid.Row="2" x:Name="StationsGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowHeight="28" CanUserResizeRows="False"
                  MouseDoubleClick="StationsGrid_DoubleClick"
                  SelectionChanged="StationsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static loc:L.ColName}" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="{x:Static loc:L.ColCountry}" Binding="{Binding CountryCode}" Width="70"/>
                <DataGridTextColumn Header="{x:Static loc:L.ColTags}" Binding="{Binding Tags}" Width="2*"/>
                <DataGridTextColumn Header="{x:Static loc:L.ColLanguage}" Binding="{Binding Language}" Width="100"/>
                <DataGridTextColumn Header="{x:Static loc:L.ColCodec}" Binding="{Binding Codec}" Width="70"/>
                <DataGridTextColumn Header="{x:Static loc:L.ColBitrate}" Binding="{Binding Bitrate}" Width="70"/>
                <DataGridTextColumn Header="{x:Static loc:L.ColClicks}" Binding="{Binding ClickCount}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{x:Static loc:L.UrlLabel}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="1" x:Name="SelectedUrlBox"
                     IsReadOnly="True" Padding="6,4" Foreground="#666"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusText"
                       Foreground="#666" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="{x:Static loc:L.DiscoveryCancelButton}" Click="Cancel_Click"
                        Padding="12,6" MinWidth="80" IsCancel="True"/>
                <Button x:Name="OkButton" Content="{x:Static loc:L.DiscoverySelectButton}" Click="Ok_Click"
                        IsEnabled="False" IsDefault="True"
                        Padding="12,6" MinWidth="100" Margin="8,0,0,0"
                        Background="#0078D4" Foreground="White" BorderBrush="#0078D4"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
