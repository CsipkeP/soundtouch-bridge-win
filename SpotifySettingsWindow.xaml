<Window x:Class="BoseSoundTouchBridge.SpotifySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:BoseSoundTouchBridge.Localization"
        Title="{x:Static loc:L.SpotifyTitle}"
        Width="640" Height="540"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="13"
        Icon="Assets/app.ico"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{x:Static loc:L.SpotifyHeader}"
                   FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Background="#FFFBE6" BorderBrush="#E5D080" BorderThickness="1"
                CornerRadius="4" Padding="12" Margin="0,0,0,16">
            <TextBlock TextWrapping="Wrap" LineHeight="20">
                <Run Text="{x:Static loc:L.SpotifyInstrStep1Pre}"/>
                <Hyperlink NavigateUri="https://developer.spotify.com/dashboard"
                           RequestNavigate="Hyperlink_RequestNavigate">developer.spotify.com/dashboard</Hyperlink>
                <Run Text="{x:Static loc:L.SpotifyInstrStep1Post}"/>
                <LineBreak/>
                <Run Text="{x:Static loc:L.SpotifyInstrStep2Pre}"/>
                <Run FontWeight="SemiBold" FontFamily="Consolas" Text="http://127.0.0.1:38765/callback"/>
                <LineBreak/>
                <Run Text="{x:Static loc:L.SpotifyInstrStep3}"/>
                <LineBreak/>
                <Run Text="{x:Static loc:L.SpotifyInstrStep4}"/>
            </TextBlock>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{x:Static loc:L.SpotifyClientIdLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" x:Name="ClientIdBox" Padding="6,4"
                     VerticalContentAlignment="Center" FontFamily="Consolas"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,16">
            <Button x:Name="ConnectButton" Content="{x:Static loc:L.SpotifyConnectAction}"
                    Click="Connect_Click" Padding="14,7" MinWidth="200"
                    Background="#1DB954" Foreground="White" BorderBrush="#1DB954" FontWeight="SemiBold"/>
            <Button x:Name="DisconnectButton" Content="{x:Static loc:L.SpotifyDisconnectAction}"
                    Click="Disconnect_Click" Padding="14,7" Margin="8,0,0,0"
                    IsEnabled="False"/>
        </StackPanel>

        <Border Grid.Row="4" BorderBrush="#DDD" BorderThickness="0,1,0,1" Padding="0,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="Gray"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" Text="{x:Static loc:L.SpotifyNotConnected}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="5" Text="{x:Static loc:L.SpotifyDeviceLabel}"
                   FontWeight="SemiBold" Margin="0,0,0,6"/>

        <Grid Grid.Row="6" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Row="0" Grid.Column="0" x:Name="DeviceCombo"
                      Padding="6,4"
                      SelectionChanged="DeviceCombo_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Static loc:L.SpotifyDeviceActive}"
                                           Foreground="#1DB954" FontSize="11"
                                           VerticalAlignment="Center" Margin="6,0,0,0"
                                           Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                            <TextBlock FontSize="11" Foreground="#888" TextTrimming="CharacterEllipsis">
                                <Run Text="{x:Static loc:L.SpotifyDeviceTypeLabel}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding Type, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text="  ·  "/>
                                <Run Text="{x:Static loc:L.SpotifyDeviceIdLabel}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding Id, Mode=OneWay}" FontFamily="Consolas"/>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Row="0" Grid.Column="1" Content="{x:Static loc:L.SpotifyTestDeviceButton}"
                    Click="TestDevice_Click" Padding="10,4" MinWidth="80" Margin="8,0,0,0"
                    ToolTip="{x:Static loc:L.SpotifyTestDeviceTooltip}"/>
            <Button Grid.Row="0" Grid.Column="2" Content="{x:Static loc:L.SpotifyRefreshButton}"
                    Click="RefreshDevices_Click" Padding="10,4" MinWidth="80" Margin="8,0,0,0"/>

            <TextBlock Grid.Row="1" Grid.ColumnSpan="3"
                       Text="{x:Static loc:L.SpotifyDeviceHint}"
                       FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,6,0,0"/>
        </Grid>

        <Grid Grid.Row="7" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="HintText"
                       Foreground="#666" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            <Button Grid.Column="1" Content="{x:Static loc:L.CloseButton}" Click="Close_Click"
                    Padding="14,6" MinWidth="84" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
